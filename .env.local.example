# ⚠️ IMPORTANT: Do NOT commit this file with real values. Use .env.local.example as a template.
# This file is listed in .gitignore and will not be committed.
# Copy to .env.local and fill in your actual API keys for local development.

# Gemini API (optional fallback)
# Get your key from: https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# AI/ML API (primary)
# Get your key from: https://aimlapi.com
AI_ML_API_KEY=your_aiml_api_key_here
AI_ML_API_MODEL=google/gemini-3-1-pro-preview
AI_ML_API_BASE_URL=https://api.aimlapi.com
AI_ML_API_AUTH_HEADER=Authorization
AI_ML_API_AUTH_SCHEME=Bearer

# Hackathon mode: stricter moderation thresholds (Gemini + local checks)
AI_HACKATHON_STRICT_MODERATION=true